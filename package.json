{
  "name": "algoviz",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-driven algorithm visualization learning platform",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "proxy": "node server/proxy.cjs",
    "start": "node server/proxy.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint src server vite.config.ts vitest.config.ts eslint.config.js",
    "format": "prettier --write src"
  },
  "keywords": [
    "algorithm",
    "visualization",
    "AI",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "d3": "^7.9.0",
    "framer-motion": "^12.40.0",
    "i18next": "^26.2.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
